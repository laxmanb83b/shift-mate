# Copy to .env and fill in. Safe to expose the anon key client-side (RLS protects data).
EXPO_PUBLIC_SUPABASE_URL=https://YOUR-PROJECT.supabase.co
EXPO_PUBLIC_SUPABASE_ANON_KEY=YOUR-ANON-KEY

# Server-side ONLY (set as a Supabase Edge Function secret, never in the app):
# SIGHTENGINE_API_USER=xxxxx
# SIGHTENGINE_API_SECRET=xxxxx
