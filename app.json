{
  "expo": {
    "name": "ShiftMate",
    "slug": "shiftmate",
    "version": "1.0.0",
    "orientation": "portrait",
    "scheme": "shiftmate",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "icon": "./assets/icon.png",
    "splash": {
      "image": "./assets/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#4f46e5"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.laxmanb.shiftmate",
      "buildNumber": "1",
      "infoPlist": {
        "NSPhotoLibraryUsageDescription": "ShiftMate needs access to your photos so you can attach a picture to a job posting.",
        "ITSAppUsesNonExemptEncryption": false
      }
    },
    "android": {
      "package": "com.laxmanb.shiftmate",
      "versionCode": 1,
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#4f46e5"
      },
      "permissions": ["READ_MEDIA_IMAGES"]
    },
    "web": {
      "bundler": "metro",
      "output": "static",
      "favicon": "./assets/favicon.png"
    },
    "plugins": ["expo-router", "expo-image-picker"],
    "experiments": {
      "typedRoutes": false
    },
    "extra": {
      "supabaseUrl": "https://YOUR-PROJECT.supabase.co",
      "supabaseAnonKey": "YOUR-ANON-KEY",
      "eas": {
        "projectId": "PASTE-AFTER-eas-init"
      }
    }
  }
}
